# Cortex — Environment Configuration
# Copy this file to .env and fill in your values.
# Works on all platforms (macOS, Linux, Windows).

# AI Provider — set at least one (checked in this order)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROK_API_KEY=

# Data directory — default is .cortex-data/ in the project root
# Examples:
#   CORTEX_DATA_DIR=C:\Users\you\OneDrive\cortex-data    (Windows)
#   CORTEX_DATA_DIR=/Users/you/Google Drive/cortex-data   (macOS)
#   CORTEX_DATA_DIR=/home/you/Dropbox/cortex-data         (Linux)
CORTEX_DATA_DIR=

# Server port — default 5000
PORT=5000
